<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" fill="none">
  <!-- Background circle with gradient -->
  <defs>
    <linearGradient id="bg-grad" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#e11d48" />
      <stop offset="100%" stop-color="#be123c" />
    </linearGradient>
    <linearGradient id="icon-grad" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#fda4af" />
      <stop offset="100%" stop-color="#fff" />
    </linearGradient>
    <filter id="glow">
      <feDropShadow dx="0" dy="2" stdDeviation="4" flood-color="#e11d48" flood-opacity="0.3"/>
    </filter>
  </defs>

  <!-- Glow behind -->
  <circle cx="100" cy="100" r="95" fill="#e11d48" opacity="0.08"/>

  <!-- Main circle -->
  <circle cx="100" cy="100" r="80" fill="url(#bg-grad)"/>

  <!-- Form icon - checkmark -->
  <g filter="url(#glow)">
    <!-- Document outline -->
    <rect x="65" y="48" width="70" height="88" rx="8" stroke="url(#icon-grad)" stroke-width="3" fill="none" opacity="0.9"/>

    <!-- Lines on document -->
    <line x1="78" y1="68" x2="122" y2="68" stroke="url(#icon-grad)" stroke-width="2" stroke-linecap="round" opacity="0.5"/>
    <line x1="78" y1="80" x2="122" y2="80" stroke="url(#icon-grad)" stroke-width="2" stroke-linecap="round" opacity="0.5"/>
    <line x1="78" y1="92" x2="110" y2="92" stroke="url(#icon-grad)" stroke-width="2" stroke-linecap="round" opacity="0.5"/>

    <!-- Checkmark -->
    <path d="M78 112 L92 126 L122 100" stroke="url(#icon-grad)" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
  </g>
</svg>
